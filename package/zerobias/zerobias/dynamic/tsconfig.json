{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2024",
    "lib": ["es2024"],
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["node", "mocha", "chai"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*",
    "generated/**/*",
    "test/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
