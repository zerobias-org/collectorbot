{
  "name": "@zerobias-org/collectorbot-zerobias-zerobias-dynamic",
  "version": "1.0.0",
  "description": "ZeroBias Data Producer Interface Collector",
  "type": "module",
  "main": "dist/src/index.js",
  "author": "ctamas@zerobias.com",
  "license": "UNLICENSED",
  "directories": {
    "src": "src"
  },
  "files": [
    "dist",
    "npm-shrinkwrap.json",
    "*.yml",
    "*.md"
  ],
  "scripts": {
    "nx:build": "npm run build",
    "build": "npm run generate && npm run transpile",
    "clean": "rm -rf generated && rm -rf dist",
    "generate": "npm run generate:models && npm run generate:hub-client",
    "generate:hub-client": "node -e \"import('@zerobias-com/hub-client-codegen')\"",
    "generate:models": "hub-generator generate -g hub-module -i ./parameters.yml -o generated/ --global-property models,supportingFiles=index.ts && rm ./generated/api/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "test": "",
    "test:integration": "mocha --exit --inline-diffs --reporter=list test/integration/**/*.ts",
    "transpile": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:zerobias-org/collectorbot.git",
    "directory": "package/zerobias/zerobias/dynamic"
  },
  "dependencies": {
    "@zerobias-com/hub-client": "latest",
    "@zerobias-com/hub-core": "latest",
    "@zerobias-com/platform-sdk": "latest",
    "@zerobias-org/data-utils": "^1.0.28",
    "@zerobias-org/module-interface-dataproducer": "latest",
    "@zerobias-org/product-zerobias-zerobias": "latest",
    "@zerobias-org/types-core-js": "latest",
    "@zerobias-org/util-collector": "^1.0.34",
    "inversify": "6.0.2",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "@zerobias-com/hub-client-codegen": "^1.0.37",
    "@zerobias-com/hub-secrets-manager": "latest",
    "@zerobias-org/util-codegen": "latest",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "zerobias": {
    "package": "zerobias.zerobias.dynamic.collectorbot",
    "dataloader-version": "1.0.0",
    "import-artifact": "collectorbot"
  }
}
